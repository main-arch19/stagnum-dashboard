# Database (PostgreSQL on Supabase or Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/stagnum_dashboard?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Cloudflare R2 (S3-compatible storage for photos/PDFs)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="stagnum-assets"
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# DocuSign (e-signature)
DOCUSIGN_INTEGRATION_KEY=""
DOCUSIGN_SECRET_KEY=""
DOCUSIGN_ACCOUNT_ID=""
DOCUSIGN_BASE_URL="https://demo.docusign.net/restapi"

# QuickBooks Online
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
QBO_ENVIRONMENT="sandbox"

# WhatsApp Business API
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""

# Google Drive
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
GOOGLE_DRIVE_ROOT_FOLDER_ID=""

# Exchange Rate API (Bank of Jamaica or similar)
BOJ_API_KEY=""
