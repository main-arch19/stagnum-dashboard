generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  FOUNDER
  PM
  QS
  SUPERVISOR
  ADMIN
  SUBCONTRACTOR
}

enum Currency {
  JMD
  USD
}

enum ProjectStage {
  ENQUIRY
  QUOTING
  AWAITING_SIGNATURE
  AWAITING_DEPOSIT
  MOBILIZATION
  PROCUREMENT
  CONSTRUCTION
  HANDOVER
  CLOSEOUT
  CLOSED
  ON_HOLD
  CANCELLED
}

enum GateStatus {
  LOCKED
  UNLOCKED
  BYPASSED
}

enum QuotationStatus {
  DRAFT
  SENT
  SIGNED
  SUPERSEDED
  REJECTED
}

enum POStatus {
  DRAFT
  ISSUED
  PARTIAL_DELIVERY
  DELIVERED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  WRITTEN_OFF
}

enum ChecklistItemStatus {
  PENDING
  PASSED
  FAILED
  NA
}

enum InspectionStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  APPROVED
}

enum AssetType {
  EQUIPMENT
  DRONE
  VEHICLE
}

enum MaintenanceStatus {
  DUE
  OVERDUE
  COMPLETED
}

enum TenderStatus {
  PROSPECT
  QUALIFIED
  TENDER_PREP
  SUBMITTED
  SHORTLISTED
  WON
  LOST
  NO_BID
}

enum SystemType {
  SOLAR
  RAINWATER
  WIND
  ENERGY_AUDIT
}

// ─── AUTH / USERS ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String?
  role         UserRole
  passwordHash String
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedProjects   ProjectMember[]
  authoredQuotations Quotation[]        @relation("QuotedBy")
  approvedVariations Variation[]        @relation("ApprovedBy")
  inspections        Inspection[]
  siteLogEntries     SiteLog[]
  timesheets         LabourTimesheet[]
  auditLogs          AuditLog[]
  gateOverrides      StageGateEvent[]   @relation("OverriddenBy")

  @@map("users")
}

// ─── MASTER RATES LIBRARY ─────────────────────────────────────────────────────

model RateCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  sortOrder   Int     @default(0)
  rates       Rate[]

  @@map("rate_categories")
}

model Rate {
  id          String       @id @default(cuid())
  code        String       @unique
  description String
  unit        String
  categoryId  String
  category    RateCategory @relation(fields: [categoryId], references: [id])
  isComposite Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  versions RateVersion[]
  boqItems BOQItem[]

  @@map("rates")
}

model RateVersion {
  id              String    @id @default(cuid())
  rateId          String
  rate            Rate      @relation(fields: [rateId], references: [id])
  version         Int
  labourCostJMD   Decimal   @db.Decimal(15, 2)
  materialCostJMD Decimal   @db.Decimal(15, 2)
  overheadPct     Decimal   @db.Decimal(5, 4)
  profitPct       Decimal   @db.Decimal(5, 4)
  unitRateJMD     Decimal   @db.Decimal(15, 2)
  unitRateUSD     Decimal   @db.Decimal(15, 2)
  exchangeRate    Decimal   @db.Decimal(10, 4)
  isStale         Boolean   @default(false)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  createdById     String
  notes           String?

  components CompositeRateComponent[]

  @@unique([rateId, version])
  @@map("rate_versions")
}

model CompositeRateComponent {
  id              String      @id @default(cuid())
  parentVersionId String
  parentVersion   RateVersion @relation(fields: [parentVersionId], references: [id])
  childRateCode   String
  quantity        Decimal     @db.Decimal(10, 4)
  notes           String?

  @@map("composite_rate_components")
}

// ─── CLIENTS & PROJECTS ───────────────────────────────────────────────────────

model Client {
  id                String   @id @default(cuid())
  name              String
  company           String?
  email             String?
  phone             String?
  address           String?
  taxNumber         String?
  preferredCurrency Currency @default(JMD)
  createdAt         DateTime @default(now())

  projects Project[]

  @@map("clients")
}

model Project {
  id               String       @id @default(cuid())
  projectNumber    String       @unique
  name             String
  description      String?
  clientId         String
  client           Client       @relation(fields: [clientId], references: [id])
  stage            ProjectStage @default(ENQUIRY)
  contractValueJMD Decimal?     @db.Decimal(15, 2)
  contractValueUSD Decimal?     @db.Decimal(15, 2)
  currency         Currency     @default(JMD)
  siteAddress      String?
  siteLat          Decimal?     @db.Decimal(10, 8)
  siteLng          Decimal?     @db.Decimal(11, 8)
  startDate        DateTime?
  estimatedEndDate DateTime?
  actualEndDate    DateTime?
  depositPct       Decimal      @default(0.30) @db.Decimal(5, 4)
  depositClearedAt DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  mobilizationGate GateStatus @default(LOCKED)
  procurementGate  GateStatus @default(LOCKED)
  constructionGate GateStatus @default(LOCKED)
  handoverGate     GateStatus @default(LOCKED)
  closeoutGate     GateStatus @default(LOCKED)

  members            ProjectMember[]
  stageGateEvents    StageGateEvent[]
  quotations         Quotation[]
  variations         Variation[]
  boqs               BOQ[]
  constructionStages ConstructionStage[]
  purchaseOrders     PurchaseOrder[]
  invoices           Invoice[]
  inspections        Inspection[]
  siteLogs           SiteLog[]
  labourSchedule     LabourScheduleEntry[]
  qcChecklists       QCChecklist[]
  punchListItems     PunchListItem[]
  sustainableSystems SustainableSystem[]
  tenderRecord       TenderRecord?
  auditLogs          AuditLog[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      UserRole
  addedAt   DateTime @default(now())

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── STAGE GATE EVENTS (immutable audit trail) ────────────────────────────────

model StageGateEvent {
  id                String     @id @default(cuid())
  projectId         String
  project           Project    @relation(fields: [projectId], references: [id])
  gate              String
  previousStatus    GateStatus
  newStatus         GateStatus
  triggeredById     String
  triggeredBy       User       @relation("OverriddenBy", fields: [triggeredById], references: [id])
  isOverride        Boolean    @default(false)
  overrideReason    String?
  conditionSnapshot Json
  occurredAt        DateTime   @default(now())

  @@map("stage_gate_events")
}

// ─── BOQ & PRICING ────────────────────────────────────────────────────────────

model BOQ {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  version     Int       @default(1)
  name        String    @default("Primary BOQ")
  isApproved  Boolean   @default(false)
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items      BOQItem[]
  quotations Quotation[]

  @@unique([projectId, version])
  @@map("boqs")
}

model BOQItem {
  id            String   @id @default(cuid())
  boqId         String
  boq           BOQ      @relation(fields: [boqId], references: [id])
  rateId        String?
  rate          Rate?    @relation(fields: [rateId], references: [id])
  rateVersionId String?
  description   String
  unit          String
  quantity      Decimal  @db.Decimal(12, 4)
  unitRateJMD   Decimal  @db.Decimal(15, 2)
  totalJMD      Decimal  @db.Decimal(15, 2)
  section       String?
  sortOrder     Int      @default(0)
  notes         String?
  isAllowance   Boolean  @default(false)

  @@map("boq_items")
}

// ─── QUOTATIONS & VARIATIONS ──────────────────────────────────────────────────

model Quotation {
  id           String          @id @default(cuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id])
  boqId        String?
  boq          BOQ?            @relation(fields: [boqId], references: [id])
  quotedById   String
  quotedBy     User            @relation("QuotedBy", fields: [quotedById], references: [id])
  version      Int             @default(1)
  status       QuotationStatus @default(DRAFT)
  totalJMD     Decimal         @db.Decimal(15, 2)
  totalUSD     Decimal?        @db.Decimal(15, 2)
  validUntil   DateTime
  terms        String?
  signedAt     DateTime?
  signedByName String?
  signatureRef String?
  signedDocUrl String?
  sentAt       DateTime?
  pdfUrl       String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([projectId, version])
  @@map("quotations")
}

model Variation {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id])
  variationNumber Int
  title           String
  description     String
  valueJMD        Decimal   @db.Decimal(15, 2)
  approved        Boolean   @default(false)
  approvedById    String?
  approvedBy      User?     @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  signedAt        DateTime?
  signatureRef    String?
  signedDocUrl    String?
  createdAt       DateTime  @default(now())

  @@unique([projectId, variationNumber])
  @@map("variations")
}

// ─── CONSTRUCTION STAGES ──────────────────────────────────────────────────────

model ConstructionStage {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id])
  name         String
  sortOrder    Int
  startDate    DateTime?
  endDate      DateTime?
  physicalPct  Decimal   @default(0) @db.Decimal(5, 2)
  financialPct Decimal   @default(0) @db.Decimal(5, 2)
  isComplete   Boolean   @default(false)
  completedAt  DateTime?

  checklists QCChecklist[]

  @@map("construction_stages")
}

// ─── QA / QC & PUNCH LIST ─────────────────────────────────────────────────────

model QCChecklist {
  id           String             @id @default(cuid())
  projectId    String
  project      Project            @relation(fields: [projectId], references: [id])
  stageId      String?
  stage        ConstructionStage? @relation(fields: [stageId], references: [id])
  title        String
  templateName String?
  isComplete   Boolean            @default(false)
  completedAt  DateTime?
  createdAt    DateTime           @default(now())

  items QCChecklistItem[]

  @@map("qc_checklists")
}

model QCChecklistItem {
  id            String              @id @default(cuid())
  checklistId   String
  checklist     QCChecklist         @relation(fields: [checklistId], references: [id])
  description   String
  status        ChecklistItemStatus @default(PENDING)
  inspectedById String?
  notes         String?
  photoUrls     String[]            @default([])
  completedAt   DateTime?

  @@map("qc_checklist_items")
}

model PunchListItem {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  description String
  location    String?
  assignedTo  String?
  dueDate     DateTime?
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
  photoUrls   String[]  @default([])
  createdAt   DateTime  @default(now())

  @@map("punch_list_items")
}

// ─── PROCUREMENT ──────────────────────────────────────────────────────────────

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contact        String?
  email          String?
  phone          String?
  address        String?
  taxNumber      String?
  rating         Int?
  createdAt      DateTime        @default(now())
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id])
  supplierId       String
  supplier         Supplier  @relation(fields: [supplierId], references: [id])
  poNumber         String    @unique
  status           POStatus  @default(DRAFT)
  totalJMD         Decimal   @db.Decimal(15, 2)
  issuedAt         DateTime?
  expectedDelivery DateTime?
  deliveredAt      DateTime?
  notes            String?
  createdAt        DateTime  @default(now())

  items POItem[]

  @@map("purchase_orders")
}

model POItem {
  id          String        @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id])
  description String
  unit        String
  quantity    Decimal       @db.Decimal(12, 4)
  unitCostJMD Decimal       @db.Decimal(15, 2)
  totalJMD    Decimal       @db.Decimal(15, 2)

  @@map("po_items")
}

// ─── LABOUR & SUBCONTRACTORS ──────────────────────────────────────────────────

model LabourScheduleEntry {
  id                   String   @id @default(cuid())
  projectId            String
  project              Project  @relation(fields: [projectId], references: [id])
  workerName           String
  trade                String
  isSubcontractor      Boolean  @default(false)
  subcontractorCompany String?
  startDate            DateTime
  endDate              DateTime
  dailyRateJMD         Decimal  @db.Decimal(10, 2)
  boqBudgetRef         String?
  notes                String?

  timesheets LabourTimesheet[]

  @@map("labour_schedule_entries")
}

model LabourTimesheet {
  id              String              @id @default(cuid())
  scheduleEntryId String
  scheduleEntry   LabourScheduleEntry @relation(fields: [scheduleEntryId], references: [id])
  workDate        DateTime            @db.Date
  hoursWorked     Decimal             @db.Decimal(5, 2)
  taskDescription String?
  recordedById    String
  recordedBy      User                @relation(fields: [recordedById], references: [id])
  createdAt       DateTime            @default(now())

  @@map("labour_timesheets")
}

// ─── INVOICING & CASH FLOW ────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id])
  invoiceNumber  String        @unique
  status         InvoiceStatus @default(DRAFT)
  subtotalJMD    Decimal       @db.Decimal(15, 2)
  taxPct         Decimal       @default(0.15) @db.Decimal(5, 4)
  taxJMD         Decimal       @db.Decimal(15, 2)
  totalJMD       Decimal       @db.Decimal(15, 2)
  isFinalInvoice Boolean       @default(false)
  sentAt         DateTime?
  dueDate        DateTime
  paidAt         DateTime?
  paidAmountJMD  Decimal?      @db.Decimal(15, 2)
  pdfUrl         String?
  qbSyncId       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  description String
  quantity    Decimal @db.Decimal(12, 4)
  unitRate    Decimal @db.Decimal(15, 2)
  totalJMD    Decimal @db.Decimal(15, 2)
  sortOrder   Int     @default(0)

  @@map("invoice_line_items")
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  amountJMD Decimal  @db.Decimal(15, 2)
  receivedAt DateTime
  method    String?
  reference String?
  isDeposit Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())

  @@map("payments")
}

// ─── INSPECTIONS & REPORTS ────────────────────────────────────────────────────

model Inspection {
  id             String           @id @default(cuid())
  projectId      String
  project        Project          @relation(fields: [projectId], references: [id])
  inspectorId    String
  inspector      User             @relation(fields: [inspectorId], references: [id])
  title          String
  status         InspectionStatus @default(DRAFT)
  inspectionDate DateTime
  templateName   String?
  observations   String?
  conclusion     String?
  lat            Decimal?         @db.Decimal(10, 8)
  lng            Decimal?         @db.Decimal(11, 8)
  locationNote   String?
  pdfUrl         String?
  submittedAt    DateTime?
  reviewedAt     DateTime?
  approvedAt     DateTime?
  createdAt      DateTime         @default(now())

  photos InspectionPhoto[]

  @@map("inspections")
}

model InspectionPhoto {
  id           String     @id @default(cuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id])
  url          String
  thumbnailUrl String?
  caption      String?
  lat          Decimal?   @db.Decimal(10, 8)
  lng          Decimal?   @db.Decimal(11, 8)
  takenAt      DateTime?
  uploadedAt   DateTime   @default(now())

  @@map("inspection_photos")
}

// ─── SITE LOGS ────────────────────────────────────────────────────────────────

model SiteLog {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id])
  authorId         String
  author           User     @relation(fields: [authorId], references: [id])
  logDate          DateTime @db.Date
  weatherCondition String?
  workforceCount   Int?
  activities       String
  issues           String?
  photoUrls        String[] @default([])
  createdAt        DateTime @default(now())

  @@map("site_logs")
}

// ─── ASSETS & EQUIPMENT ───────────────────────────────────────────────────────

model Asset {
  id               String    @id @default(cuid())
  assetTag         String    @unique
  name             String
  type             AssetType
  make             String?
  model            String?
  serialNumber     String?
  purchaseDate     DateTime?
  purchaseCostJMD  Decimal?  @db.Decimal(15, 2)
  currentProjectId String?
  isActive         Boolean   @default(true)
  flightHours      Decimal?  @db.Decimal(8, 2)
  notes            String?

  maintenanceLogs AssetMaintenance[]

  @@map("assets")
}

model AssetMaintenance {
  id            String            @id @default(cuid())
  assetId       String
  asset         Asset             @relation(fields: [assetId], references: [id])
  scheduledDate DateTime
  completedAt   DateTime?
  status        MaintenanceStatus @default(DUE)
  description   String
  costJMD       Decimal?          @db.Decimal(10, 2)
  performedBy   String?
  notes         String?

  @@map("asset_maintenance")
}

// ─── TENDER / BD PIPELINE ─────────────────────────────────────────────────────

model TenderRecord {
  id                 String       @id @default(cuid())
  projectId          String       @unique
  project            Project      @relation(fields: [projectId], references: [id])
  status             TenderStatus @default(PROSPECT)
  estimatedValueJMD  Decimal?     @db.Decimal(15, 2)
  source             String?
  competitorCount    Int?
  submittedAt        DateTime?
  resultDate         DateTime?
  winProbabilityPct  Decimal?     @db.Decimal(5, 2)
  lossReason         String?
  notes              String?
  updatedAt          DateTime     @updatedAt

  @@map("tender_records")
}

// ─── SUSTAINABLE SYSTEMS ──────────────────────────────────────────────────────

model SustainableSystem {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id])
  systemType  SystemType
  capacityKw  Decimal?   @db.Decimal(8, 2)
  panelCount  Int?
  installedAt DateTime?
  auditScore  Decimal?   @db.Decimal(5, 2)
  notes       String?

  @@map("sustainable_systems")
}

// ─── AUDIT LOG (immutable ledger) ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  entity     String
  entityId   String
  action     String
  oldValue   Json?
  newValue   Json?
  reason     String?
  ipAddress  String?
  occurredAt DateTime @default(now())

  @@map("audit_logs")
}
